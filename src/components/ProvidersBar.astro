---
const categoryColors: Record<string, string> = {
  'STT': '#00D4FF',
  'LLM': '#A78BFA',
  'TTS': '#34D399',
  'Telephony': '#FBBF24',
};

const providers = [
  {
    name: 'Deepgram',
    category: 'STT',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="4" y="14" width="3" height="6" rx="1"/><rect x="10.5" y="8" width="3" height="12" rx="1"/><rect x="17" y="4" width="3" height="16" rx="1"/></svg>`,
  },
  {
    name: 'OpenAI',
    category: 'STT · LLM · TTS',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><circle cx="12" cy="5" r="1.5"/><circle cx="18" cy="9" r="1.5"/><circle cx="18" cy="15" r="1.5"/><circle cx="12" cy="19" r="1.5"/><circle cx="6" cy="15" r="1.5"/><circle cx="6" cy="9" r="1.5"/></svg>`,
  },
  {
    name: 'Anthropic',
    category: 'LLM',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 12l10 10 10-10L12 2z"/><circle cx="12" cy="12" r="2"/></svg>`,
  },
  {
    name: 'Google Gemini',
    category: 'LLM',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2l1.5 4.5L18 8l-4.5 1.5L12 14l-1.5-4.5L6 8l4.5-1.5L12 2z"/><path d="M17 14l1 3 3 1-3 1-1 3-1-3-3-1 3-1 1-3z"/></svg>`,
  },
  {
    name: 'Groq',
    category: 'LLM',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  },
  {
    name: 'ElevenLabs',
    category: 'TTS',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="9" y1="4" x2="9" y2="20"/><line x1="15" y1="4" x2="15" y2="20"/></svg>`,
  },
  {
    name: 'PlayHT',
    category: 'TTS',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="6 3 20 12 6 21 6 3"/></svg>`,
  },
  {
    name: 'Twilio',
    category: 'Telephony',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 8.81 19.79 19.79 0 010 .18 2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92z"/></svg>`,
  },
];

function getPrimaryCategory(cat: string): string {
  const first = cat.split(' · ')[0];
  return categoryColors[first] || '#64748B';
}
---

<section id="providers" class="py-14 overflow-hidden">
  <!-- Glow divider top -->
  <div class="section-glow-divider mb-14"></div>

  <div class="max-w-7xl mx-auto px-6 mb-8 text-center">
    <p class="text-sm font-medium tracking-widest uppercase relative inline-block" style="color: #4A5F75; letter-spacing: 0.12em;">
      Works with 10+ providers across the AI stack
    </p>
  </div>

  <!-- Marquee track -->
  <div class="marquee-container relative flex overflow-hidden" style="mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);">
    <div class="animate-marquee flex shrink-0 gap-0">
      {providers.concat(providers).map((p) => {
        const color = getPrimaryCategory(p.category);
        return (
          <div
            class="provider-card flex items-center gap-3 mx-4 px-4 py-3 rounded-lg border shrink-0 transition-all duration-300"
            style={`border-color: #1E293B; background-color: #0D1117; min-width: 175px; border-left: 2px solid ${color};`}
          >
            <div class="w-8 h-8 rounded-md flex items-center justify-center shrink-0" style={`color: ${color}; background-color: ${color}15;`} set:html={p.icon} />
            <div class="flex flex-col">
              <span class="font-display font-semibold text-sm provider-name" style="color: #94A3B8;">{p.name}</span>
              <span class="text-xs" style="color: #3D526B;">{p.category}</span>
            </div>
          </div>
        );
      })}
    </div>
    <!-- Second copy for seamless loop -->
    <div class="animate-marquee flex shrink-0 gap-0" aria-hidden="true">
      {providers.concat(providers).map((p) => {
        const color = getPrimaryCategory(p.category);
        return (
          <div
            class="provider-card flex items-center gap-3 mx-4 px-4 py-3 rounded-lg border shrink-0 transition-all duration-300"
            style={`border-color: #1E293B; background-color: #0D1117; min-width: 175px; border-left: 2px solid ${color};`}
          >
            <div class="w-8 h-8 rounded-md flex items-center justify-center shrink-0" style={`color: ${color}; background-color: ${color}15;`} set:html={p.icon} />
            <div class="flex flex-col">
              <span class="font-display font-semibold text-sm provider-name" style="color: #94A3B8;">{p.name}</span>
              <span class="text-xs" style="color: #3D526B;">{p.category}</span>
            </div>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Provider categories legend -->
  <div class="max-w-7xl mx-auto px-6 mt-8 flex flex-wrap justify-center gap-4">
    {[
      { label: 'STT', desc: 'Speech-to-Text', color: '#00D4FF' },
      { label: 'LLM', desc: 'Language Model', color: '#A78BFA' },
      { label: 'TTS', desc: 'Text-to-Speech', color: '#34D399' },
      { label: 'Telephony', desc: 'Phone / WebRTC', color: '#FBBF24' },
    ].map(c => (
      <div class="flex items-center gap-2 text-xs" style="color: #64748B;">
        <span class="w-2 h-2 rounded-full" style={`background-color: ${c.color};`}></span>
        <span style="color: #94A3B8;">{c.label}</span>
        <span>{c.desc}</span>
      </div>
    ))}
  </div>

  <!-- Glow divider bottom -->
  <div class="section-glow-divider mt-14"></div>
</section>

<style>
  .marquee-container:hover .animate-marquee {
    animation-play-state: paused;
  }

  .provider-card:hover {
    border-color: rgba(0, 212, 255, 0.3) !important;
    background-color: rgba(0, 212, 255, 0.05) !important;
    box-shadow: -4px 0 16px rgba(0, 212, 255, 0.08);
  }
  .provider-card:hover .provider-name {
    color: #F1F5F9 !important;
  }
</style>
