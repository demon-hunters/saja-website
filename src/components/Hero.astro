---
const GITHUB_URL = 'https://github.com/saja-voice/saja';

// Tokenized code lines for rich syntax highlighting
const codeLines = [
  [
    { text: 'from', type: 'kw' }, { text: ' ', type: '' },
    { text: 'saja.agent', type: 'mod' }, { text: ' ', type: '' },
    { text: 'import', type: 'kw' }, { text: ' ', type: '' },
    { text: 'AgentConfig', type: 'cls' }, { text: ', ', type: 'pn' },
    { text: 'AgentPersona', type: 'cls' },
  ],
  [
    { text: 'from', type: 'kw' }, { text: ' ', type: '' },
    { text: 'saja.agent', type: 'mod' }, { text: ' ', type: '' },
    { text: 'import', type: 'kw' }, { text: ' ', type: '' },
    { text: 'AgentProviderConfig', type: 'cls' },
  ],
  [
    { text: 'from', type: 'kw' }, { text: ' ', type: '' },
    { text: 'saja.agent', type: 'mod' }, { text: ' ', type: '' },
    { text: 'import', type: 'kw' }, { text: ' ', type: '' },
    { text: 'AgentFactory', type: 'cls' }, { text: ', ', type: 'pn' },
    { text: 'RuntimeSession', type: 'cls' },
  ],
  [],
  [
    { text: 'config', type: '' }, { text: ' = ', type: 'pn' },
    { text: 'AgentConfig', type: 'cls' }, { text: '(', type: 'pn' },
  ],
  [
    { text: '    persona', type: '' }, { text: '=', type: 'pn' },
    { text: 'AgentPersona', type: 'cls' }, { text: '(', type: 'pn' },
  ],
  [
    { text: '        name', type: '' }, { text: '=', type: 'pn' },
    { text: '"Aria"', type: 'str' }, { text: ',', type: 'pn' },
  ],
  [
    { text: '        system_prompt', type: '' }, { text: '=', type: 'pn' },
    { text: '"You are a helpful assistant."', type: 'str' }, { text: ',', type: 'pn' },
  ],
  [
    { text: '    ),', type: 'pn' },
  ],
  [
    { text: '    provider', type: '' }, { text: '=', type: 'pn' },
    { text: 'AgentProviderConfig', type: 'cls' }, { text: '(', type: 'pn' },
  ],
  [
    { text: '        preferred_stt_provider', type: '' }, { text: '=', type: 'pn' },
    { text: '"deepgram"', type: 'str' }, { text: ',', type: 'pn' },
  ],
  [
    { text: '        preferred_llm_provider', type: '' }, { text: '=', type: 'pn' },
    { text: '"claude"', type: 'str' }, { text: ',', type: 'pn' },
  ],
  [
    { text: '        preferred_tts_provider', type: '' }, { text: '=', type: 'pn' },
    { text: '"elevenlabs"', type: 'str' }, { text: ',', type: 'pn' },
  ],
  [
    { text: '    ),', type: 'pn' },
  ],
  [
    { text: ')', type: 'pn' },
  ],
  [],
  [
    { text: 'session', type: '' }, { text: ' = ', type: 'pn' },
    { text: 'RuntimeSession', type: 'cls' }, { text: '(', type: 'pn' },
    { text: 'session_id', type: '' }, { text: '=', type: 'pn' },
    { text: '"demo-001"', type: 'str' }, { text: ')', type: 'pn' },
  ],
  [
    { text: 'agent', type: '' }, { text: ' = ', type: 'pn' },
    { text: 'await', type: 'kw' }, { text: ' ', type: '' },
    { text: 'AgentFactory', type: 'cls' }, { text: '.', type: 'pn' },
    { text: 'create_agent', type: 'fn' }, { text: '(', type: 'pn' },
    { text: 'config', type: '' }, { text: ', ', type: 'pn' },
    { text: 'session', type: '' }, { text: ')', type: 'pn' },
  ],
  [
    { text: 'await', type: 'kw' }, { text: ' ', type: '' },
    { text: 'agent', type: '' }, { text: '.', type: 'pn' },
    { text: 'start', type: 'fn' }, { text: '()  ', type: 'pn' },
    { text: '# real-time voice begins', type: 'cm' },
  ],
];

const stats = [
  {
    label: '10+ providers',
    icon: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  },
  {
    label: 'Apache 2.0',
    icon: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
  },
  {
    label: 'Python 3.10+',
    icon: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  },
];
---

<section id="hero" class="relative overflow-hidden py-24 px-6">
  <!-- Background gradient glow with pulse -->
  <div
    class="absolute inset-0 pointer-events-none hero-bg-glow"
    style="background: radial-gradient(ellipse 70% 50% at 60% 40%, rgba(0, 212, 255, 0.06) 0%, transparent 70%), radial-gradient(ellipse 50% 40% at 20% 60%, rgba(124, 58, 237, 0.05) 0%, transparent 70%);"
  ></div>
  <!-- Secondary pulse blob -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 40% 35% at 70% 30%, rgba(0, 212, 255, 0.04) 0%, transparent 70%); animation: pulse-glow 8s ease-in-out infinite;"
  ></div>

  <div class="max-w-7xl mx-auto relative">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Left column -->
      <div class="flex flex-col gap-6">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 w-fit px-3 py-1.5 rounded-full text-sm font-medium border"
          style="background-color: rgba(0, 212, 255, 0.08); border-color: rgba(0, 212, 255, 0.2); color: #00D4FF;">
          <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background-color: #00D4FF;"></span>
          Open source · Apache 2.0
        </div>

        <!-- Headline -->
        <h1 class="font-display font-bold leading-tight" style="font-size: clamp(2.4rem, 5vw, 3.5rem); color: #F1F5F9; letter-spacing: -0.02em;">
          Build real-time<br />
          <span class="gradient-text">voice agents</span><br />
          in Python
        </h1>

        <!-- Description -->
        <p class="text-lg leading-relaxed max-w-xl" style="color: #94A3B8;">
          saja is an open-source framework that wires <span style="color: #F1F5F9; font-weight: 500;">STT → LLM → TTS</span> into a composable,
          interruptible, production-ready voice pipeline — with multi-provider support,
          tool use, and full observability.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-3 pt-2">
          <a
            href={GITHUB_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="hero-cta-primary inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold text-sm transition-all"
            style="background-color: #00D4FF; color: #080C14;"
          >
            Get Started
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
          <a
            href={GITHUB_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="hero-cta-secondary inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold text-sm transition-all border"
            style="color: #F1F5F9; border-color: #2D3F55; background-color: transparent;"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
            View on GitHub
          </a>
        </div>

        <!-- Stats row -->
        <div class="flex flex-wrap gap-x-6 gap-y-2 pt-1">
          {stats.map(s => (
            <div class="flex items-center gap-2 text-sm" style="color: #64748B;">
              <span style="color: #4A5F75;" set:html={s.icon} />
              <span>{s.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right column — terminal card + waveform -->
      <div class="flex flex-col">
        <div
          class="terminal-card rounded-t-xl overflow-hidden"
          style="background-color: #0D1117; border: 1px solid #1E293B; border-bottom: none;"
        >
          <!-- Terminal chrome with file tabs -->
          <div class="flex items-center gap-2 px-4 py-3 border-b" style="border-color: #1E293B;">
            <span class="w-3 h-3 rounded-full" style="background-color: #FF5F57;"></span>
            <span class="w-3 h-3 rounded-full" style="background-color: #FEBC2E;"></span>
            <span class="w-3 h-3 rounded-full" style="background-color: #28C840;"></span>
            <div class="ml-3 flex items-center">
              <span class="text-xs px-3 py-1 rounded-t border-b-2" style="color: #94A3B8; font-family: 'JetBrains Mono', monospace; border-bottom-color: #00D4FF; background-color: rgba(0, 212, 255, 0.05);">
                voice_agent.py
              </span>
              <span class="text-xs px-3 py-1" style="color: #2D3F55; font-family: 'JetBrains Mono', monospace;">
                requirements.txt
              </span>
            </div>
          </div>

          <!-- Code content with line numbers -->
          <div class="p-5 overflow-x-auto" style="font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; line-height: 1.75;">
            {codeLines.map((tokens, i) => (
              <div
                class="code-line flex whitespace-pre"
                style={`opacity: 0; animation: fadeInLine 0.15s ease forwards; animation-delay: ${i * 70}ms;`}
              >
                <span class="line-number select-none text-right shrink-0" style="width: 28px; margin-right: 16px; color: #2D3F55; font-size: 0.7rem;">
                  {i + 1}
                </span>
                <span class="line-content">
                  {tokens.length === 0 ? '\u200B' : tokens.map(t => {
                    if (t.type === '') return t.text;
                    return <span class={`tok-${t.type}`}>{t.text}</span>;
                  })}
                </span>
              </div>
            ))}
            <!-- Cursor -->
            <div class="flex">
              <span class="select-none" style="width: 28px; margin-right: 16px;"></span>
              <div class="animate-blink inline-block w-2 h-4 align-middle mt-1" style="background-color: #00D4FF;"></div>
            </div>
          </div>
        </div>

        <!-- Waveform — connected to terminal -->
        <div
          class="flex items-center gap-1 px-5 py-3 rounded-b-xl"
          style="background-color: #0D1117; border: 1px solid #1E293B; border-top: 1px solid #141B26;"
        >
          <span class="text-xs mr-3 flex items-center gap-1.5 shrink-0" style="color: #3D526B; font-family: 'JetBrains Mono', monospace;">
            <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background-color: #34D399;"></span>
            SAJA Pipeline Active
          </span>
          <div class="flex items-center gap-0.5 flex-1 justify-end">
            {Array.from({ length: 24 }).map((_, i) => (
              <div
                class="rounded-full"
                style={`
                  width: 2.5px;
                  height: 20px;
                  background: linear-gradient(to top, #00D4FF, #A78BFA);
                  opacity: ${0.3 + Math.random() * 0.7};
                  transform-origin: center;
                  animation: wave-bar ${0.6 + Math.random() * 0.8}s ease-in-out infinite alternate;
                  animation-delay: ${i * 40}ms;
                `}
              ></div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInLine {
    from { opacity: 0; transform: translateX(-4px); }
    to { opacity: 1; transform: translateX(0); }
  }
  @keyframes wave-bar {
    from { transform: scaleY(0.25); }
    to { transform: scaleY(1); }
  }

  .terminal-card {
    box-shadow: 0 0 80px rgba(0, 212, 255, 0.1), 0 0 30px rgba(0, 212, 255, 0.05), 0 25px 50px rgba(0, 0, 0, 0.5);
    transition: box-shadow 0.4s ease;
  }
  .terminal-card:hover {
    box-shadow: 0 0 80px rgba(0, 212, 255, 0.15), 0 0 30px rgba(0, 212, 255, 0.08), 0 25px 50px rgba(0, 0, 0, 0.5);
  }

  /* Syntax token colors */
  .tok-kw { color: #7DD3FC; }
  .tok-cls { color: #FCD34D; }
  .tok-str { color: #86EFAC; }
  .tok-cm { color: #4A5F75; font-style: italic; }
  .tok-fn { color: #C4B5FD; }
  .tok-pn { color: #64748B; }
  .tok-mod { color: #CBD5E1; }

  .hero-cta-primary {
    box-shadow: 0 0 20px rgba(0, 212, 255, 0.2);
    transition: all 0.2s ease;
  }
  .hero-cta-primary:hover {
    background-color: #00BAE0 !important;
    transform: scale(1.02);
    box-shadow: 0 0 30px rgba(0, 212, 255, 0.3);
  }

  .hero-cta-secondary:hover {
    border-color: #4A5F75 !important;
    background-color: rgba(255, 255, 255, 0.04) !important;
  }

  .hero-bg-glow {
    animation: pulse-glow 8s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }
</style>
