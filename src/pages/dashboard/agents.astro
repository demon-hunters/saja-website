---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---
<DashboardLayout title="Agents" activeSection="agents">
  <Fragment slot="topbar-actions">
    <a href="/dashboard/builder" class="btn btn-primary">+ New Agent</a>
  </Fragment>

  <div id="agents-container">
    <div class="empty-state">
      <div class="empty-state-icon">⏳</div>
      <div class="empty-state-title">Loading agents...</div>
    </div>
  </div>

  <!-- Simulate modal -->
  <div class="modal-backdrop" id="sim-modal">
    <div class="modal">
      <div class="modal-header">
        <span class="modal-title">Simulate Agent</span>
        <button class="close-btn" onclick="closeSimModal()">✕</button>
      </div>
      <div class="form-group">
        <label class="form-label">Your Message</label>
        <textarea class="textarea" id="sim-input" placeholder="Hello, I need help scheduling an appointment..." style="min-height:80px"></textarea>
      </div>
      <div class="form-group">
        <label class="form-label">System Prompt Override (optional)</label>
        <textarea class="textarea" id="sim-system" placeholder="Leave blank to use agent's default prompt" style="min-height:60px"></textarea>
      </div>
      <div style="display:flex;gap:10px;margin-bottom:16px">
        <label style="display:flex;align-items:center;gap:6px;font-size:13px;color:var(--text-dim);cursor:pointer">
          <input type="checkbox" id="sim-initiate" style="accent-color:var(--accent)" />
          Initiate (agent speaks first)
        </label>
      </div>
      <div style="display:flex;gap:8px">
        <button class="btn btn-primary flex-1" onclick="runSimulation()">Run Simulation</button>
        <button class="btn btn-ghost" onclick="closeSimModal()">Cancel</button>
      </div>
      <div id="sim-result" style="margin-top:16px;display:none">
        <hr class="divider" />
        <div style="font-size:12.5px;font-weight:600;color:var(--text-dim);margin-bottom:10px;text-transform:uppercase;letter-spacing:0.5px">Result</div>
        <div id="sim-output"></div>
      </div>
    </div>
  </div>

  <script>
    let currentAgentId = null;

    async function loadAgents() {
      try {
        const data = await window.apiFetch('/agents');
        renderAgents(data.agents || []);
      } catch (e) {
        document.getElementById('agents-container').innerHTML = `
          <div class="empty-state">
            <div class="empty-state-icon">⚠️</div>
            <div class="empty-state-title">Could not load agents</div>
            <div class="empty-state-desc">${e.message}<br/><br/>Make sure the SAJA backend is running and your API key is configured in <a href="/dashboard/settings" style="color:var(--accent)">Settings</a>.</div>
          </div>`;
      }
    }

    function renderAgents(agents) {
      if (!agents.length) {
        document.getElementById('agents-container').innerHTML = `
          <div class="empty-state">
            <div class="empty-state-icon">🤖</div>
            <div class="empty-state-title">No agents yet</div>
            <div class="empty-state-desc">Create your first voice agent to get started.</div>
            <div style="margin-top:16px"><a href="/dashboard/builder" class="btn btn-primary">+ Create Agent</a></div>
          </div>`;
        return;
      }

      const rows = agents.map(a => `
        <tr>
          <td>
            <div style="font-weight:600">${a.name}</div>
            <div class="text-muted text-sm">${a.description || ''}</div>
          </td>
          <td>
            ${a.preset_name ? `<span class="badge badge-blue">${a.preset_name}</span>` : '<span class="text-muted">custom</span>'}
          </td>
          <td>
            ${a.is_builtin ? '<span class="badge badge-gray">Built-in</span>' : '<span class="badge badge-green">Custom</span>'}
          </td>
          <td class="text-dim">${a.preferred_tts_provider || '—'}</td>
          <td class="text-dim">${a.llm_model || '—'}</td>
          <td>
            <div style="display:flex;gap:6px">
              <button class="btn btn-ghost btn-sm" onclick='openSimModal("${a.id}")'>Test</button>
              ${!a.is_builtin ? `<a href="/dashboard/builder?id=${a.id}" class="btn btn-ghost btn-sm">Edit</a>` : ''}
              ${!a.is_builtin ? `<button class="btn btn-danger btn-sm" onclick='deleteAgent("${a.id}","${a.name}")'>Delete</button>` : ''}
            </div>
          </td>
        </tr>`).join('');

      document.getElementById('agents-container').innerHTML = `
        <div class="card" style="padding:0;overflow:hidden">
          <table class="table">
            <thead>
              <tr>
                <th>Agent</th>
                <th>Preset</th>
                <th>Type</th>
                <th>TTS</th>
                <th>LLM</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>${rows}</tbody>
          </table>
        </div>`;
    }

    function openSimModal(agentId) {
      currentAgentId = agentId;
      document.getElementById('sim-result').style.display = 'none';
      document.getElementById('sim-modal').classList.add('show');
    }

    function closeSimModal() {
      document.getElementById('sim-modal').classList.remove('show');
      currentAgentId = null;
    }

    async function runSimulation() {
      const input = document.getElementById('sim-input').value.trim();
      const sysOverride = document.getElementById('sim-system').value.trim();
      const initiate = document.getElementById('sim-initiate').checked;
      if (!input && !initiate) { window.showToast('Enter a message or check Initiate', 'error'); return; }

      try {
        const result = await window.apiFetch(`/agents/${currentAgentId}/simulate`, {
          method: 'POST',
          body: JSON.stringify({
            turns: input ? [input] : [],
            initiate,
            system_prompt_override: sysOverride || undefined,
          }),
        });

        const html = result.turns.map(t => `
          <div style="margin-bottom:14px">
            ${t.input ? `<div style="background:var(--surface2);border-radius:8px;padding:10px 12px;margin-bottom:6px;font-size:13px"><strong>You:</strong> ${t.input}</div>` : ''}
            <div style="background:rgba(59,130,246,0.08);border:1px solid rgba(59,130,246,0.2);border-radius:8px;padding:10px 12px;font-size:13px"><strong>Agent:</strong> ${t.response}</div>
          </div>`).join('');

        document.getElementById('sim-output').innerHTML = html || '<div class="text-dim">No output.</div>';
        document.getElementById('sim-result').style.display = 'block';
      } catch (e) {
        window.showToast('Simulation failed: ' + e.message, 'error');
      }
    }

    async function deleteAgent(id, name) {
      if (!confirm(`Delete agent "${name}"? This cannot be undone.`)) return;
      try {
        await window.apiFetch(`/agents/${id}`, { method: 'DELETE' });
        window.showToast('Agent deleted', 'success');
        loadAgents();
      } catch (e) {
        window.showToast('Delete failed: ' + e.message, 'error');
      }
    }

    document.getElementById('sim-modal').addEventListener('click', e => {
      if (e.target === e.currentTarget) closeSimModal();
    });

    loadAgents();
  </script>
</DashboardLayout>
