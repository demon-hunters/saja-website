---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---
<DashboardLayout title="Settings" activeSection="settings">

  <div style="max-width:680px">

    <!-- Account section -->
    <div class="card mb-4">
      <div class="card-header">
        <span class="card-title">Account</span>
      </div>
      <div id="account-section">
        <div class="text-dim text-sm mb-4">Sign in to manage your agents and settings, or create a new account.</div>

        <!-- Login form (shown when not logged in) -->
        <div id="login-form">
          <div class="grid-2">
            <div class="form-group">
              <label class="form-label">Email</label>
              <input class="input" id="login-email" type="email" placeholder="you@example.com" />
            </div>
            <div class="form-group">
              <label class="form-label">Password</label>
              <input class="input" id="login-password" type="password" placeholder="••••••••" />
            </div>
          </div>
          <div style="display:flex;gap:8px">
            <button class="btn btn-primary" onclick="doLogin()">Sign In</button>
            <button class="btn btn-ghost" onclick="showRegister()">Create Account</button>
          </div>
        </div>

        <!-- Register form (hidden by default) -->
        <div id="register-form" style="display:none">
          <div class="form-group">
            <label class="form-label">Organization Name</label>
            <input class="input" id="reg-org" type="text" placeholder="Acme Corp" />
          </div>
          <div class="grid-2">
            <div class="form-group">
              <label class="form-label">Email</label>
              <input class="input" id="reg-email" type="email" placeholder="you@example.com" />
            </div>
            <div class="form-group">
              <label class="form-label">Password</label>
              <input class="input" id="reg-password" type="password" placeholder="••••••••" />
            </div>
          </div>
          <div style="display:flex;gap:8px">
            <button class="btn btn-primary" onclick="doRegister()">Create Account</button>
            <button class="btn btn-ghost" onclick="showLogin()">Back to Sign In</button>
          </div>
        </div>

        <!-- Logged in view -->
        <div id="logged-in-view" style="display:none">
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px">
            <div style="width:40px;height:40px;background:var(--accent);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;color:#fff" id="user-avatar">?</div>
            <div>
              <div style="font-weight:600" id="user-email"></div>
              <div class="text-dim text-sm"><span id="user-role"></span> · <span id="user-org"></span></div>
            </div>
            <button class="btn btn-ghost btn-sm" style="margin-left:auto" onclick="doLogout()">Sign Out</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Backend connection -->
    <div class="card mb-4">
      <div class="card-header">
        <span class="card-title">Backend Connection</span>
      </div>
      <p class="text-dim text-sm mb-4">The dashboard connects to a running SAJA backend. Configure the URL and API key here.</p>
      <div class="form-group">
        <label class="form-label">Backend URL</label>
        <input class="input" id="backend-url" type="url" placeholder="http://localhost:8000" />
      </div>
      <div class="form-group">
        <label class="form-label">API Key (X-API-Key)</label>
        <input class="input" id="api-key-field" type="password" placeholder="Enter API key if AUTH is enabled" />
      </div>
      <div style="display:flex;gap:8px;align-items:center">
        <button class="btn btn-primary" onclick="saveConnectionSettings()">Save</button>
        <button class="btn btn-ghost" onclick="testConnection()">Test Connection</button>
        <span id="connection-status" style="font-size:13px;color:var(--text-dim)"></span>
      </div>
    </div>

    <!-- API Keys management (shown when logged in) -->
    <div class="card mb-4" id="api-keys-card" style="display:none">
      <div class="card-header">
        <span class="card-title">API Keys</span>
        <button class="btn btn-primary btn-sm" onclick="openCreateKey()">+ New Key</button>
      </div>
      <div id="api-keys-list">
        <div class="text-dim text-sm" style="padding:12px">Loading...</div>
      </div>
    </div>

    <!-- Team members (shown when logged in) -->
    <div class="card" id="team-card" style="display:none">
      <div class="card-header">
        <span class="card-title">Team Members</span>
        <button class="btn btn-ghost btn-sm" onclick="openInvite()">+ Invite</button>
      </div>
      <div id="team-list">
        <div class="text-dim text-sm" style="padding:12px">Loading...</div>
      </div>
    </div>
  </div>

  <!-- Create API key modal -->
  <div class="modal-backdrop" id="create-key-modal">
    <div class="modal">
      <div class="modal-header">
        <span class="modal-title">Create API Key</span>
        <button class="close-btn" onclick="closeModal('create-key-modal')">✕</button>
      </div>
      <div class="form-group">
        <label class="form-label">Key Name</label>
        <input class="input" id="new-key-name" type="text" placeholder="e.g. Production Backend" />
      </div>
      <div class="form-group">
        <label class="form-label">Role</label>
        <select class="select" id="new-key-role">
          <option value="service">Service (API access)</option>
          <option value="admin">Admin (full access)</option>
          <option value="viewer">Viewer (read-only)</option>
        </select>
      </div>
      <button class="btn btn-primary w-full" style="justify-content:center" onclick="createKey()">Create Key</button>

      <div id="new-key-result" style="display:none;margin-top:16px">
        <hr class="divider" />
        <div class="form-label" style="margin-bottom:8px">Your New API Key</div>
        <div style="background:var(--surface2);border-radius:8px;padding:12px;font-family:'JetBrains Mono',monospace;font-size:12px;word-break:break-all" id="new-key-display"></div>
        <div class="text-sm text-dim mt-4" style="margin-top:8px">⚠️ Copy this key now — it will not be shown again.</div>
        <button class="btn btn-ghost w-full" style="margin-top:8px;justify-content:center" onclick="copyKey()">Copy to Clipboard</button>
      </div>
    </div>
  </div>

  <!-- Invite user modal -->
  <div class="modal-backdrop" id="invite-modal">
    <div class="modal">
      <div class="modal-header">
        <span class="modal-title">Invite Team Member</span>
        <button class="close-btn" onclick="closeModal('invite-modal')">✕</button>
      </div>
      <div class="form-group">
        <label class="form-label">Email</label>
        <input class="input" id="invite-email" type="email" placeholder="colleague@example.com" />
      </div>
      <div class="form-group">
        <label class="form-label">Temporary Password</label>
        <input class="input" id="invite-password" type="password" placeholder="They can change this later" />
      </div>
      <div class="form-group">
        <label class="form-label">Role</label>
        <select class="select" id="invite-role">
          <option value="admin">Admin</option>
          <option value="viewer">Viewer (read-only)</option>
        </select>
      </div>
      <button class="btn btn-primary w-full" style="justify-content:center" onclick="sendInvite()">Invite</button>
    </div>
  </div>

  <script>
    let currentUser = null;
    let newKeyRaw = '';

    function init() {
      // Load saved settings
      const savedUrl = localStorage.getItem('saja_backend_url') || '';
      const savedKey = localStorage.getItem('saja_api_key') || '';
      if (savedUrl) document.getElementById('backend-url').value = savedUrl;
      if (savedKey) document.getElementById('api-key-field').value = savedKey;

      // Check if JWT token exists
      const token = localStorage.getItem('saja_jwt');
      if (token) checkAuth(token);
    }

    async function checkAuth(token) {
      try {
        const res = await fetch((localStorage.getItem('saja_backend_url') || 'http://localhost:8000') + '/api/v1/auth/me', {
          headers: { 'Authorization': `Bearer ${token}` },
        });
        if (res.ok) {
          const data = await res.json();
          setLoggedIn(data);
        } else {
          localStorage.removeItem('saja_jwt');
        }
      } catch (e) {}
    }

    function setLoggedIn(user) {
      currentUser = user;
      document.getElementById('login-form').style.display = 'none';
      document.getElementById('register-form').style.display = 'none';
      document.getElementById('logged-in-view').style.display = 'block';
      document.getElementById('api-keys-card').style.display = 'block';
      document.getElementById('team-card').style.display = 'block';

      const email = user.email || '';
      document.getElementById('user-email').textContent = email;
      document.getElementById('user-avatar').textContent = email.charAt(0).toUpperCase();
      document.getElementById('user-role').textContent = user.role || '';
      document.getElementById('user-org').textContent = user.org_id ? user.org_id.slice(0, 8) + '…' : '';

      loadApiKeys();
      loadTeam();
    }

    function showRegister() {
      document.getElementById('login-form').style.display = 'none';
      document.getElementById('register-form').style.display = 'block';
    }

    function showLogin() {
      document.getElementById('register-form').style.display = 'none';
      document.getElementById('login-form').style.display = 'block';
    }

    async function doLogin() {
      const email = document.getElementById('login-email').value.trim();
      const password = document.getElementById('login-password').value;
      const base = localStorage.getItem('saja_backend_url') || 'http://localhost:8000';
      try {
        const res = await fetch(base + '/api/v1/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password }),
        });
        if (!res.ok) {
          const err = await res.json();
          window.showToast(err.detail || 'Login failed', 'error');
          return;
        }
        const data = await res.json();
        localStorage.setItem('saja_jwt', data.access_token);
        setLoggedIn({ email, role: data.role, org_id: data.org_id, user_id: data.user_id });
        window.showToast('Signed in!', 'success');
      } catch (e) {
        window.showToast('Login failed: ' + e.message, 'error');
      }
    }

    async function doRegister() {
      const org_name = document.getElementById('reg-org').value.trim();
      const email = document.getElementById('reg-email').value.trim();
      const password = document.getElementById('reg-password').value;
      const base = localStorage.getItem('saja_backend_url') || 'http://localhost:8000';
      try {
        const res = await fetch(base + '/api/v1/auth/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ org_name, email, password }),
        });
        if (!res.ok) {
          const err = await res.json();
          window.showToast(err.detail || 'Registration failed', 'error');
          return;
        }
        const data = await res.json();
        localStorage.setItem('saja_jwt', data.access_token);
        setLoggedIn({ email, role: 'owner', org_id: data.org?.id });
        window.showToast('Account created!', 'success');
      } catch (e) {
        window.showToast('Registration failed: ' + e.message, 'error');
      }
    }

    function doLogout() {
      localStorage.removeItem('saja_jwt');
      currentUser = null;
      document.getElementById('logged-in-view').style.display = 'none';
      document.getElementById('login-form').style.display = 'block';
      document.getElementById('api-keys-card').style.display = 'none';
      document.getElementById('team-card').style.display = 'none';
      window.showToast('Signed out', 'success');
    }

    function saveConnectionSettings() {
      const url = document.getElementById('backend-url').value.trim().replace(/\/$/, '');
      const key = document.getElementById('api-key-field').value.trim();
      if (url) localStorage.setItem('saja_backend_url', url);
      if (key) localStorage.setItem('saja_api_key', key);
      else localStorage.removeItem('saja_api_key');
      window.showToast('Connection settings saved', 'success');
    }

    async function testConnection() {
      const base = document.getElementById('backend-url').value.trim() || 'http://localhost:8000';
      const key = document.getElementById('api-key-field').value.trim();
      const status = document.getElementById('connection-status');
      status.textContent = 'Testing…';
      try {
        const headers = {};
        if (key) headers['X-API-Key'] = key;
        const res = await fetch(base + '/api/v1/health', { headers });
        if (res.ok) {
          status.textContent = '✅ Connected';
          status.style.color = 'var(--green)';
        } else {
          status.textContent = `⚠️ HTTP ${res.status}`;
          status.style.color = 'var(--yellow)';
        }
      } catch (e) {
        status.textContent = '❌ Cannot connect';
        status.style.color = 'var(--red)';
      }
    }

    async function loadApiKeys() {
      if (!currentUser) return;
      try {
        const token = localStorage.getItem('saja_jwt');
        const base = localStorage.getItem('saja_backend_url') || 'http://localhost:8000';
        const res = await fetch(base + '/api/v1/auth/api-keys', {
          headers: { 'Authorization': `Bearer ${token}` },
        });
        const data = await res.json();
        const keys = data.api_keys || [];
        if (!keys.length) {
          document.getElementById('api-keys-list').innerHTML = '<div class="text-dim" style="padding:12px">No API keys yet.</div>';
          return;
        }
        document.getElementById('api-keys-list').innerHTML = `
          <table class="table">
            <thead><tr><th>Name</th><th>Prefix</th><th>Role</th><th>Last Used</th><th></th></tr></thead>
            <tbody>${keys.map(k => `
              <tr>
                <td style="font-weight:500">${k.name}</td>
                <td class="mono">${k.prefix}…</td>
                <td><span class="badge badge-gray">${k.role}</span></td>
                <td class="text-dim text-sm">${k.last_used_at ? new Date(k.last_used_at).toLocaleString() : 'Never'}</td>
                <td><button class="btn btn-danger btn-sm" onclick='revokeKey("${k.id}")'>Revoke</button></td>
              </tr>`).join('')}
            </tbody>
          </table>`;
      } catch (e) {
        document.getElementById('api-keys-list').innerHTML = `<div class="text-dim" style="padding:12px">Error: ${e.message}</div>`;
      }
    }

    async function loadTeam() {
      if (!currentUser) return;
      try {
        const token = localStorage.getItem('saja_jwt');
        const base = localStorage.getItem('saja_backend_url') || 'http://localhost:8000';
        const res = await fetch(base + '/api/v1/auth/users', {
          headers: { 'Authorization': `Bearer ${token}` },
        });
        const data = await res.json();
        const users = data.users || [];
        document.getElementById('team-list').innerHTML = `
          <table class="table">
            <thead><tr><th>Email</th><th>Role</th><th>Joined</th></tr></thead>
            <tbody>${users.map(u => `
              <tr>
                <td style="font-weight:500">${u.email}</td>
                <td><span class="badge badge-blue">${u.role}</span></td>
                <td class="text-dim text-sm">${u.created_at ? new Date(u.created_at).toLocaleDateString() : '—'}</td>
              </tr>`).join('')}
            </tbody>
          </table>`;
      } catch (e) {
        document.getElementById('team-list').innerHTML = `<div class="text-dim" style="padding:12px">Error: ${e.message}</div>`;
      }
    }

    function openCreateKey() { document.getElementById('create-key-modal').classList.add('show'); document.getElementById('new-key-result').style.display='none'; }
    function openInvite() { document.getElementById('invite-modal').classList.add('show'); }
    function closeModal(id) { document.getElementById(id).classList.remove('show'); }

    async function createKey() {
      const name = document.getElementById('new-key-name').value.trim();
      const role = document.getElementById('new-key-role').value;
      if (!name) { window.showToast('Enter a key name', 'error'); return; }
      try {
        const token = localStorage.getItem('saja_jwt');
        const base = localStorage.getItem('saja_backend_url') || 'http://localhost:8000';
        const res = await fetch(base + '/api/v1/auth/api-keys', {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, role }),
        });
        const data = await res.json();
        newKeyRaw = data.raw_key || '';
        document.getElementById('new-key-display').textContent = newKeyRaw;
        document.getElementById('new-key-result').style.display = 'block';
        loadApiKeys();
      } catch (e) {
        window.showToast('Error: ' + e.message, 'error');
      }
    }

    function copyKey() {
      navigator.clipboard.writeText(newKeyRaw).then(() => window.showToast('Copied!', 'success'));
    }

    async function revokeKey(id) {
      if (!confirm('Revoke this API key?')) return;
      try {
        const token = localStorage.getItem('saja_jwt');
        const base = localStorage.getItem('saja_backend_url') || 'http://localhost:8000';
        await fetch(base + `/api/v1/auth/api-keys/${id}`, {
          method: 'DELETE',
          headers: { 'Authorization': `Bearer ${token}` },
        });
        window.showToast('Key revoked', 'success');
        loadApiKeys();
      } catch (e) {
        window.showToast('Error: ' + e.message, 'error');
      }
    }

    async function sendInvite() {
      const email = document.getElementById('invite-email').value.trim();
      const password = document.getElementById('invite-password').value;
      const role = document.getElementById('invite-role').value;
      if (!email || !password) { window.showToast('Email and password required', 'error'); return; }
      try {
        const token = localStorage.getItem('saja_jwt');
        const base = localStorage.getItem('saja_backend_url') || 'http://localhost:8000';
        await fetch(base + '/api/v1/auth/users/invite', {
          method: 'POST',
          headers: { 'Authorization': `Bearer ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password, role }),
        });
        window.showToast('User invited!', 'success');
        closeModal('invite-modal');
        loadTeam();
      } catch (e) {
        window.showToast('Error: ' + e.message, 'error');
      }
    }

    document.querySelectorAll('.modal-backdrop').forEach(el =>
      el.addEventListener('click', e => { if (e.target === e.currentTarget) el.classList.remove('show'); })
    );

    init();
  </script>
</DashboardLayout>
